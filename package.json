{
  "name": "my-tasks-pwa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "لیست کارهای من — یک PWA فارسی، سریع و خصوصی برای مدیریت وظایف روزانه",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && vitest run && vite build"
  },
  "dependencies": {
    "@fontsource-variable/vazirmatn": "^5.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
