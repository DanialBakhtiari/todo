# Apache config for the deployed site (cPanel host).
# The served /todo/ folder is a git clone of the `deploy` branch, so hide the
# VCS metadata from the web.
RedirectMatch 404 /\.git

# Gzip text responses (better LCP).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/manifest+json
</IfModule>

<IfModule mod_headers.c>
  # Fingerprinted build assets never change → cache hard.
  <FilesMatch "\.(css|js|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Keep the shell + service worker fresh so new versions roll out immediately.
  <FilesMatch "^(sw\.js|index\.html|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
